# Command implementations

cmd_init() {
    local project_path="${1:-.}"

    echo -e "${GREEN}🚀 Initializing dev-kid in: $project_path${NC}"

    # Run init script
    "$DEV_KID_ROOT/scripts/init.sh" "$project_path"
}

cmd_orchestrate() {
    local phase_id="${1:-default}"

    echo -e "${GREEN}📊 Creating execution plan for: $phase_id${NC}"

    # Always prefer the speckit canonical tasks.md when one exists.
    # This ensures [x] completion markers are read from the source of truth,
    # not from a stale plain-file copy in the project root.
    BRANCH=$(git branch --show-current 2>/dev/null || echo "")
    FOUND=""

    # 1. .specify/specs/{branch}/tasks.md  (speckit standard layout)
    if [ -n "$BRANCH" ] && [ -f ".specify/specs/$BRANCH/tasks.md" ]; then
        FOUND=".specify/specs/$BRANCH/tasks.md"
    fi

    # 2. specs/*/tasks.md  (dev-kid speckit convention)
    if [ -z "$FOUND" ]; then
        FOUND=$(find specs -name "tasks.md" -maxdepth 3 2>/dev/null | head -1)
    fi

    if [ -n "$FOUND" ]; then
        # Replace root tasks.md with a symlink if:
        #   - it doesn't exist yet, OR
        #   - it's a plain file (stale copy), OR
        #   - it's a symlink pointing elsewhere
        CURRENT_LINK=$(readlink tasks.md 2>/dev/null || echo "")
        if [ ! -e "tasks.md" ] || [ ! -L "tasks.md" ] || [ "$CURRENT_LINK" != "$FOUND" ]; then
            echo -e "   ${YELLOW}ℹ${NC}  Symlinking tasks.md → $FOUND (speckit canonical source)"
            ln -sf "$FOUND" tasks.md
        fi
    fi

    # Run orchestrator
    python3 "$DEV_KID_ROOT/cli/orchestrator.py" --phase-id "$phase_id"
}

