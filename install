#!/usr/bin/env bash
# Dev-Kid root install shim
# The maintained installer lives at scripts/install.sh.
# This shim exists so the documented `./install` command keeps working
# without diverging from the v2.x installer.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/scripts/install.sh" "$@"
